# linkedin-job-parser configuration. Copy to `.env` and edit.
# Every variable is optional; the defaults below match config.py. Both the CLI
# (pydantic-settings) and Docker Compose read this file.

# ── Application config (consumed by config.py / pydantic-settings) ───────────
# Defaults used when a search doesn't override them.
LJP_DEFAULT_KEYWORDS=python
LJP_DEFAULT_LOCATION=
# Max listings kept per search.
LJP_MAX_RESULTS=75
# Politeness: random delay (seconds) drawn uniformly between these per request.
LJP_REQUEST_DELAY_MIN=2.0
LJP_REQUEST_DELAY_MAX=5.0
# Pagination / retry safety rails.
LJP_MAX_PAGES=40
LJP_MAX_RETRIES=4
# SQLite path. In Docker this defaults to /data/jobs.db (a named volume).
LJP_DB_PATH=output/jobs.db

# ── Docker entrypoint: the search the container runs (LJP_SEARCH_*) ───────────
# These drive docker/entrypoint.sh; they do NOT affect the bare CLI.
LJP_SEARCH_KEYWORDS=python developer
LJP_SEARCH_LOCATION=United States
# LinkedIn geoId for precise targeting (optional; overrides location resolution).
LJP_SEARCH_GEO_ID=
# One of: remote | hybrid | on_site
LJP_SEARCH_WORKPLACE_TYPE=
LJP_SEARCH_MAX_RESULTS=25
# Set to 1 to enrich each listing via its detail page (full description,
# seniority, employment type, applicant count). Costs one extra request per job.
LJP_SEARCH_DETAILS=0

# ── Scheduler profile (docker/scheduler.sh) ──────────────────────────────────
# Seconds between scheduled runs (default 3600 = hourly).
LJP_SCHEDULE_INTERVAL=3600
